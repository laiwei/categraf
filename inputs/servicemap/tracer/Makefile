.PHONY: all clean generate

BPF_SOURCE = bpf/tcp_tracer.bpf.c
BPF_OBJECT = bpf/tcp_tracer.bpf.o
BPF_COMPRESSED = bpf/tcp_tracer.bpf.o.gz
GENERATED_GO = ebpf_programs_generated.go

CLANG ?= clang
LLVM_STRIP ?= llvm-strip
BPFTOOL ?= bpftool

# 检测架构
UNAME_M := $(shell uname -m)
ifeq ($(UNAME_M),x86_64)
	ARCH := x86_64
	GO_ARCH := amd64
endif
ifeq ($(UNAME_M),aarch64)
	ARCH := arm64
	GO_ARCH := arm64
endif
ifeq ($(UNAME_M),arm64)
	ARCH := arm64
	GO_ARCH := arm64
endif

CLANG_FLAGS := -O2 -g -target bpf -D__TARGET_ARCH_$(ARCH) \
	-Wall -Werror \
	-I/usr/include/bpf

all: $(GENERATED_GO)

# 编译 eBPF C 代码
$(BPF_OBJECT): $(BPF_SOURCE)
	@echo "Compiling eBPF program for $(ARCH)..."
	$(CLANG) $(CLANG_FLAGS) -c $< -o $@
	$(LLVM_STRIP) -g $@

# 压缩字节码
$(BPF_COMPRESSED): $(BPF_OBJECT)
	@echo "Compressing eBPF bytecode..."
	gzip -c $< > $@

# 生成 Go 嵌入代码
$(GENERATED_GO): $(BPF_COMPRESSED)
	@echo "Generating Go embed file..."
	@echo "package tracer" > $@
	@echo "" >> $@
	@echo "// Code generated by Makefile. DO NOT EDIT." >> $@
	@echo "" >> $@
	@echo "var embeddedPrograms = map[string][]EmbeddedProgram{" >> $@
	@echo "  \"$(GO_ARCH)\": {" >> $@
	@echo "    {" >> $@
	@echo "      MinKernel: \"4.14\"," >> $@
	@echo "      Flags:     \"\"," >> $@
	@echo -n "      Program:   []byte{" >> $@
	@hexdump -v -e '1/1 "0x%02x, "' $< | sed 's/, $$//' >> $@
	@echo "}," >> $@
	@echo "    }," >> $@
	@echo "  }," >> $@
	@echo "}" >> $@
	@go fmt $@ > /dev/null
	@echo "Generated $(GENERATED_GO) with embedded $(GO_ARCH) bytecode"

generate: $(GENERATED_GO)

clean:
	rm -f $(BPF_OBJECT) $(BPF_COMPRESSED) $(GENERATED_GO)
	@echo "Cleaned build artifacts"

# 帮助信息
help:
	@echo "eBPF Tracer Build System"
	@echo ""
	@echo "Targets:"
	@echo "  all        - Build and generate Go embed file (default)"
	@echo "  generate   - Generate Go embed file from existing .o.gz"
	@echo "  clean      - Remove build artifacts"
	@echo "  help       - Show this help message"
	@echo ""
	@echo "Requirements:"
	@echo "  - clang >= 10"
	@echo "  - llvm-strip"
	@echo "  - gzip"
	@echo "  - bpftool (for vmlinux.h generation)"
	@echo ""
	@echo "First time setup:"
	@echo "  cd bpf && bpftool btf dump file /sys/kernel/btf/vmlinux format c > vmlinux.h"
